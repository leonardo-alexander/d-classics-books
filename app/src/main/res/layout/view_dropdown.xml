<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dropdownView"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- SELECTED -->
    <LinearLayout
        android:id="@+id/selectedLayout"
        android:layout_width="130dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_selected"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iconSelected"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_home_selector" />

        <TextView
            android:id="@+id/txtSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:layout_marginStart="10dp"
            android:textColor="@color/text_header"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/iconArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_arrow_down"
            app:tint="@color/accent_main" />

    </LinearLayout>

    <!-- DROPDOWN -->
    <LinearLayout
        android:id="@+id/dropdownMenu"
        android:layout_width="130dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dropdown"
        android:visibility="gone"
        android:padding="16dp"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/secondary"
        >

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/itemHome"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_home_selector"
                app:tint="@color/accent_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Home"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:gravity="center_vertical"/>
        </LinearLayout>

        <!-- BOOKS -->
        <LinearLayout
            android:id="@+id/itemBooks"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_books_selector"
                app:tint="@color/accent_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Books"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:gravity="center_vertical"/>
        </LinearLayout>

        <!-- STORES -->
        <LinearLayout
            android:id="@+id/itemStores"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_stores_selector"
                app:tint="@color/accent_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Stores"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:gravity="center_vertical"/>
        </LinearLayout>

        <!-- LOGOUT -->
        <LinearLayout
            android:id="@+id/itemLogout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_logout"
                app:tint="@color/accent_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Logout"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:gravity="center_vertical"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>