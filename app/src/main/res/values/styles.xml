<resources>

    <!-- Base Button -->
    <style name="AppButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Input Placeholder -->
    <style name="Placeholder">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_underline</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/text_header</item>
        <item name="android:textColorHint">@color/text_placeholder</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_family</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>

    <!-- Typography -->
    <style name="Text">
        <item name="android:fontFamily">@font/poppins_family</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Text.H1" parent="Text">
        <item name="android:textSize">22sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_header</item>
        <item name="android:textFontWeight">600</item>
    </style>

    <style name="Text.H2" parent="Text">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
        <item name="android:letterSpacing">0.006</item>
        <item name="android:textColor">@color/text_header</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="Text.H3" parent="Text">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:letterSpacing">0.006</item>
        <item name="android:textColor">@color/text_header</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="Text.BodyPrimary" parent="Text">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
        <item name="android:letterSpacing">0.006</item>
        <item name="android:textColor">@color/text_body</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="Text.BodySecondary" parent="Text">
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">7sp</item>
        <item name="android:letterSpacing">0.006</item>
        <item name="android:textColor">@color/text_caption</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="Text.Caption" parent="Text">
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">4sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_caption</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="Text.ButtonText" parent="Text">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:letterSpacing">0.015</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textFontWeight">600</item>
    </style>

    <style name="Text.Placeholder" parent="Text">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">6sp</item>
        <item name="android:letterSpacing">0.006</item>
        <item name="android:textColor">@color/text_placeholder</item>
        <item name="android:textFontWeight">400</item>
    </style>

</resources>